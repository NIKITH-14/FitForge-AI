# Server
PORT=5000
NODE_ENV=development

# PostgreSQL (not used in current SQLite setup, kept for reference)
DATABASE_URL=postgresql://postgres:password@localhost:5432/fitness_platform

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Machine Integration
MACHINE_SECRET=machine_api_secret_key_change_in_production

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Spoonacular (Recipe Recommendations)
# Get a free key at: https://spoonacular.com/food-api
SPOONACULAR_API_KEY=your_actual_key_here

# File Upload
UPLOAD_DIR=uploads/
MAX_FILE_SIZE_MB=10

# CORS
FRONTEND_URL=http://localhost:3000
